{
  "expo": {
    "name": "Veriba",
    "slug": "prove-agence",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "prove",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EDEDEB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jrazzano.proveagence"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EDEDEB",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.jrazzano.proveagence"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Veriba uses your photo library so you can attach before and after photos.",
          "cameraPermission": "Veriba uses your camera to capture verified treatment photos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Veriba records location at capture time to verify photo chain of custody."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
